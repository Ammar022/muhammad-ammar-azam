APP_ENV=development          # development | staging | production
APP_PORT=8080
APP_NAME=secure-ai-chat-backend
APP_VERSION=1.0.0

DB_HOST=localhost
DB_PORT=5432
DB_NAME=secure_ai_chat
DB_USER=postgres
DB_PASSWORD=postgres_dev_password
DB_SSLMODE=disable           
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300     # seconds

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_ROLES_CLAIM=https://api.yourdomain.com/roles

CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
# Anti-replay window in seconds (requests older than this are rejected)
ANTI_REPLAY_WINDOW_SECONDS=300
# Maximum allowed request body size in bytes (default 1MB)
MAX_REQUEST_BODY_BYTES=1048576
# Global request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30

# Per-IP rate limits (requests per minute)
RATE_LIMIT_IP_RPM=100
# Per-user rate limits (requests per minute)
RATE_LIMIT_USER_RPM=50
# Auth endpoint rate limits (requests per minute) — stricter
RATE_LIMIT_AUTH_RPM=10
# Chat endpoint rate limits (requests per minute)
RATE_LIMIT_CHAT_RPM=20
# Subscription endpoint rate limits (requests per minute)
RATE_LIMIT_SUBSCRIPTION_RPM=30

RENEWAL_INTERVAL_MINUTES=60 #minutes


# Simulated AI response latency range in milliseconds
AI_LATENCY_MIN_MS=500
AI_LATENCY_MAX_MS=2000


LOG_LEVEL=debug              # debug | info | warn | error
LOG_FORMAT=json              
